# --- AI & Agents ---
.env
.mcp_secrets
**/memory_bank/local_*
**/node_modules
**/__pycache__
.python-version

# --- Architecture & Docs ---
# Игнорируем временные файлы редакторов диаграмм, но оставляем .md и .mmd
*.drawio.bkp
.DS_Store
Thumbs.db

# --- Infrastructure ---
.terraform/
*.tfstate
*.tfstate.backup
.aws/
.kube/config

# --- Fast-ASDLC Specific ---
# Игнорируем логи работы агентов, чтобы не забивать гит
.agents/logs/
.agents/temp/

# --- Keep empty folders ---
# Чтобы структура папок (analytics, specs) сохранялась при форке, 
# внутри них должен лежать файл .gitkeep. Эти файлы НЕ игнорируем.
!.gitkeep
